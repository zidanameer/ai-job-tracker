# Copy this file to .env and fill in real values. .env is gitignored.
#   cp .env.example .env
# Load into your shell before running the app:
#   set -a && source .env && set +a

# Google Gemini API key — get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# PostgreSQL (used by docker-compose.yml and the Spring datasource).
POSTGRES_DB=jobtracker
POSTGRES_USER=jobtracker
POSTGRES_PASSWORD=change-me

# Spring datasource overrides (optional — these are the defaults in application.yml).
# DB_URL=jdbc:postgresql://localhost:5432/jobtracker
# DB_USERNAME=jobtracker
DB_PASSWORD=change-me
